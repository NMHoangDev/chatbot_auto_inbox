# Docker/production env — copy to `.env` (KHÔNG commit .env thật).
# Dùng bởi docker-compose.yml: vừa làm build-args cho frontend (NEXT_PUBLIC_*)
# vừa làm runtime env cho cả 2 container (env_file).
#
# Cho local dev KHÔNG dùng Docker, xem `.env.local.example` thay vào đó.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Zalo Bridge
BRIDGE_API_KEY=change_me_to_a_random_string
# TODO: điền domain thật khi có (VM + domain sẽ cung cấp sau). Trước khi có
# domain, để nguyên giá trị localhost:8080 bên dưới cho môi trường test.
ZALO_BRIDGE_PUBLIC_URL=http://localhost:8080/zalo-bridge
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Tài khoản Zalo mặc định hiển thị trong UI (slug bất kỳ).
NEXT_PUBLIC_ZALO_ACCOUNT_ID=shop-owner

# Port máy ảo mở ra ngoài cho nginx router (đổi thành 80 khi gắn domain thật,
# hoặc để nguyên 8080 nếu Caddy/Cloudflare đứng trước lo TLS).
ROUTER_HTTP_PORT=8080
