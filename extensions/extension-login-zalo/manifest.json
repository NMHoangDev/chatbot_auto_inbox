{
  "manifest_version": 3,
  "name": "Markee Zalo Personal Connector",
  "version": "1.1.1",
  "description": "Connect Zalo Web session to Markee Chat through the configured Zalo bridge.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://chat.zalo.me/*",
    "https://*.zalo.me/*",
    "https://*.zaloapp.com/*",
    "https://id.zalo.me/*",
    "https://*.id.zalo.me/*",
    "https://id.zaloapp.com/*",
    "https://*.id.zaloapp.com/*",
    "https://ttailieu.zalo.me/*",
    "https://login.zalo.me/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://crm.smb.markeeai.com/*",
    "https://seeding.markeeai.com/*",
    "https://*.markeeai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.zalo.me/*",
        "https://*.zalo.me/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:4000/*",
        "http://127.0.0.1:4000/*",
        "https://*.markeeai.com/*"
      ],
      "js": ["content-script-bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "page-bridge-main.js"],
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:4000/*",
        "http://127.0.0.1:4000/*",
        "https://*.markeeai.com/*"
      ]
    }
  ]
}
